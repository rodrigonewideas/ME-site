# API de leads — NUNCA commitar o .env real (chmod 600)
DATABASE_URL="postgresql://site_writer:TROQUE_SENHA@192.168.0.82:5432/malote_site?sslmode=prefer"
ALLOWED_ORIGINS="https://www.maloteeletronico.com.br,https://maloteeletronico.com.br"
LEAD_RECIPIENT="comercial@maloteeletronico.com.br"

# SMTP do servidor de mail do dominio
SMTP_HOST="mail.maloteeletronico.com.br"
SMTP_PORT="587"
SMTP_USER="comercial@maloteeletronico.com.br"
SMTP_PASS="TROQUE_SENHA_SMTP"
SMTP_FROM="comercial@maloteeletronico.com.br"

# Anti-abuso
IP_SALT="troque-por-um-valor-aleatorio"
# Opcional: Cloudflare Turnstile (deixe vazio para desativar)
TURNSTILE_SECRET=""
