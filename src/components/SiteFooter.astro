---
const year = new Date().getFullYear();
const COMERCIAL = 'comercial@maloteeletronico.com.br';
---
<footer class="border-t border-border bg-background py-12">
  <div class="section-container">
    <div class="grid gap-8 md:grid-cols-4">
      <div class="md:col-span-1">
        <span class="text-[15px] font-bold text-foreground">Malote Eletrônico <span class="text-secondary">IA</span></span>
        <p class="mt-2 text-sm text-muted-foreground">Entenda o acervo inteiro — inclusive o que falta.</p>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-foreground">Produto</h4>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li><a href="#problema" class="hover:text-foreground">O problema</a></li>
          <li><a href="#listas" class="hover:text-foreground">A solução</a></li>
          <li><a href="#especialistas" class="hover:text-foreground">Especialistas</a></li>
          <li><a href="#aplicacoes" class="hover:text-foreground">Aplicações</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-foreground">Confiança</h4>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li><a href="#seguranca" class="hover:text-foreground">Segurança</a></li>
          <li><a href="#faq" class="hover:text-foreground">FAQ</a></li>
          <li><a href="/privacidade" class="hover:text-foreground">Privacidade / LGPD</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-semibold text-foreground">Contato</h4>
        <ul class="mt-3 space-y-2 text-sm text-muted-foreground">
          <li><a href={`mailto:${COMERCIAL}`} class="hover:text-foreground">{COMERCIAL}</a></li>
          <li><a href="#demo" class="hover:text-foreground">Agendar demonstração</a></li>
          <!-- TODO: telefone / endereco -->
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-border pt-6 text-xs text-muted-foreground">
      © {year} Malote Eletrônico IA. Todos os direitos reservados.
    </div>
  </div>
</footer>
