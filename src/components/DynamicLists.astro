---
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';
const rows = [
  { name: 'Ana Souza', doc: 'ASO admissional', falta: false },
  { name: 'Carlos Mendes', doc: 'Comprovante de residência', falta: true },
  { name: 'João Silva', doc: 'CTPS', falta: false },
  { name: 'Marina Costa', doc: 'Certificado de reservista', falta: true },
  { name: 'Pedro Lima', doc: 'Contrato de trabalho', falta: false },
];
---
<section id="listas" class="canvas-dark grid-dots relative overflow-hidden py-24 md:py-32">
  <div class="glow glow-emerald" style="width:460px;height:460px;top:-120px;left:50%;transform:translateX(-50%);opacity:.4"></div>

  <div class="section-container relative z-10">
    <SectionHeading invert eyebrow="A solução" title="A IA não só organiza." highlight="Ela aponta o que falta."
      subtitle="Para cada caso — um colaborador, uma proposta de crédito, um processo — existe um conjunto de documentos que deveria existir. A Lista Dinâmica cruza o que o acervo tem com o que ele deveria ter e revela a ausência. É auditoria por ausência, contínua." />

    <div class="mx-auto max-w-3xl" data-reveal>
      <div class="glass-panel scan-wrap overflow-hidden">
        <span class="scanline" aria-hidden="true"></span>

        <!-- chrome + status -->
        <div class="flex items-center justify-between gap-3 border-b border-white/10 px-4 py-3 md:px-5">
          <div class="flex items-center gap-3">
            <span class="window-dots"><i style="background:#ff5f57"></i><i style="background:#febc2e"></i><i style="background:#28c840"></i></span>
            <span class="font-mono text-[11px] uppercase tracking-wider text-white/45">Lista Dinâmica · auditoria por ausência</span>
          </div>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-400/30 bg-emerald-400/10 px-2.5 py-1 text-[11px] font-semibold text-emerald-300">
            <span class="dot-live"></span> 2 de 5 faltando
          </span>
        </div>

        <!-- cabecalho de colunas -->
        <div class="grid grid-cols-[1fr_1.4fr_auto] gap-x-3 px-4 pt-4 pb-2 font-mono text-[11px] uppercase tracking-wider text-white/40 md:px-5">
          <span>Colaborador</span><span>Documento esperado</span><span class="text-right">Situação</span>
        </div>

        <!-- linhas -->
        <ul class="px-2 pb-3 md:px-3">
          {rows.map((r, i) => (
            <li
              class={`rise grid grid-cols-[1fr_1.4fr_auto] items-center gap-x-3 rounded-lg px-2 py-3 md:px-3 ${r.falta ? 'bg-emerald-400/[0.07] ring-1 ring-inset ring-emerald-400/20' : ''}`}
              style={`animation-delay:${i * 130 + 200}ms`}
            >
              <span class="truncate text-sm text-white/90">{r.name}</span>
              <span class="truncate text-sm text-white/55">{r.doc}</span>
              {r.falta ? (
                <span class="ghost-cell inline-flex items-center gap-1.5 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wide">
                  <Icon name="alert-circle" class="h-3.5 w-3.5" /> falta
                </span>
              ) : (
                <span class="inline-flex items-center gap-1.5 text-[11px] font-semibold uppercase tracking-wide text-white/40">
                  <Icon name="check" class="h-3.5 w-3.5 text-emerald-400" /> ok
                </span>
              )}
            </li>
          ))}
        </ul>
      </div>

      <p class="mt-5 text-center text-sm text-slate-400">
        Não é uma busca. É o acervo <span class="text-white/80">se vigiando sozinho</span> — a cada documento que entra.
      </p>
    </div>
  </div>
</section>
