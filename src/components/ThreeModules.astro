---
import SectionHeading from './SectionHeading.astro';
import Icon from './Icon.astro';
const modules = [
  { icon: 'building', name: 'Central', role: 'Governa e licencia', body: 'Catálogo de especialistas, clientes, trilha de auditoria.', accent: 'primary' },
  { icon: 'bot', name: 'Agente', role: 'Executa o trabalho', body: 'Especialistas autônomos que fazem a tarefa de ponta a ponta.', accent: 'secondary' },
  { icon: 'folder-tree', name: 'Malote', role: 'Acervo sob controle', body: 'Onde a informação vive, organizada e auditável — para o cliente.', accent: 'navy' },
];
const pilares = [
  { t: 'Conhecimento', b: 'Busca semântica sobre a base de cada especialista. Responde só com o que sabe — não inventa.' },
  { t: 'Workflows', b: 'Orquestra tarefas automáticas, do recebimento à conclusão.' },
  { t: 'Integrações', b: 'eSocial, assinatura digital e WhatsApp — o agente age, não só responde.' },
];
---
<section id="sistema" class="bg-muted/40 py-20 md:py-28">
  <div class="section-container">
    <SectionHeading eyebrow="O sistema" title="Três módulos," highlight="um sistema."
      subtitle="Você governa no Central. Os agentes fazem o trabalho. E o resultado fica sob controle no Malote." />

    <div class="mx-auto flex max-w-5xl flex-col items-stretch gap-3 lg:flex-row lg:items-center">
      {modules.map((m, i) => (
        <>
          <div class={`flex-1 rounded-2xl border p-6 ${m.accent === 'secondary' ? 'border-secondary/40 bg-secondary/5 shadow-enterprise' : 'border-border bg-card'}`} data-reveal data-reveal-delay={String(i * 120)}>
            <span class={`inline-flex h-11 w-11 items-center justify-center rounded-xl ${m.accent === 'secondary' ? 'bg-secondary/15 text-secondary' : 'bg-primary/10 text-primary'}`}>
              <Icon name={m.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-4 text-xl font-bold text-foreground">{m.name}</h3>
            <p class="text-sm font-semibold text-secondary">{m.role}</p>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{m.body}</p>
          </div>
          {i < modules.length - 1 && (
            <div class="flex flex-col items-center text-muted-foreground" aria-hidden="true">
              <Icon name="arrow-right" class="hidden h-6 w-6 lg:block" />
              <span class="text-[11px] uppercase tracking-wider">{i === 0 ? 'ativa' : 'entrega'}</span>
            </div>
          )}
        </>
      ))}
    </div>

    <div class="mx-auto mt-8 max-w-5xl rounded-2xl border border-dashed border-border p-6" data-reveal>
      <p class="mb-4 text-sm font-semibold uppercase tracking-wider text-muted-foreground">Como o agente trabalha</p>
      <div class="grid gap-4 md:grid-cols-3">
        {pilares.map((p) => (
          <div class="rounded-xl border border-secondary/30 bg-secondary/5 p-4">
            <h4 class="text-sm font-bold text-foreground">{p.t}</h4>
            <p class="mt-1.5 text-xs leading-relaxed text-muted-foreground">{p.b}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
