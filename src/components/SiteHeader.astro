---
import MobileNav from './islands/MobileNav.tsx';
import Logo from './Logo.astro';
const links = [
  { name: 'O problema', href: '#problema' },
  { name: 'A solução', href: '#listas' },
  { name: 'Especialistas', href: '#especialistas' },
  { name: 'Segurança', href: '#seguranca' },
  { name: 'FAQ', href: '#faq' },
];
---
<header class="site-header fixed inset-x-0 top-0 z-50 border-b border-white/10 text-white backdrop-blur-md">
  <div class="section-container">
    <div class="flex h-[72px] items-center justify-between gap-4 lg:h-20">
      <a href="#inicio" aria-label="Malote Eletrônico IA — início" class="text-white">
        <Logo />
      </a>

      <nav class="hidden items-center gap-1 lg:flex">
        {links.map((l) => (
          <a href={l.href} class="nav-link text-white/70 hover:text-white">{l.name}</a>
        ))}
        <a href="#demo" class="btn-emerald ml-3 px-5 py-2.5 text-sm">Agendar demonstração</a>
      </nav>

      <div class="flex items-center gap-1 lg:hidden">
        <MobileNav client:idle />
      </div>
    </div>
  </div>
</header>
